{
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{PROJECT_ROOT}}/scripts/cc-session-start.mjs\"",
            "timeout": 120000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{PROJECT_ROOT}}/scripts/cc-session-end.mjs\"",
            "timeout": 120000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"{{PROJECT_ROOT}}/scripts/cc-on-image-prompt.ps1\"",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
